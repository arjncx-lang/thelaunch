<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF000000">

    <LinearLayout
        android:id="@+id/clockSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/ivDayNight"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="Day or night"
                android:src="@drawable/ic_sun"
                android:alpha="0.75" />

            <TextView
                android:id="@+id/tvAmPm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="AM"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_search"
                android:padding="8dp"
                android:alpha="0.5"
                android:contentDescription="Search apps" />

            <ImageView
                android:id="@+id/btnAddShortcut"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_add"
                android:padding="8dp"
                android:alpha="0.5"
                android:contentDescription="Add website shortcut" />

            <ImageView
                android:id="@+id/btnRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:padding="8dp"
                android:alpha="0.5"
                android:contentDescription="Refresh apps" />

            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:padding="8dp"
                android:alpha="0.5"
                android:contentDescription="Settings" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/search_bg"
        android:hint="Search apps"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:drawableStart="@drawable/ic_search"
        android:drawableEnd="@drawable/ic_close"
        android:drawablePadding="8dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:singleLine="true"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="28dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Apple Watch-style honeycomb (shown when Watch Mode is on). -->
        <com.oneandonly.thelaunch.WatchHoneycombView
            android:id="@+id/watchHoneycomb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Floating letter shown while scrubbing the A-Z strip (positioned in code). -->
        <TextView
            android:id="@+id/tvAlphabetBubble"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="36dp"
            android:gravity="center"
            android:textColor="#1C1C1E"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/alphabet_bubble_bg"
            android:elevation="10dp"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"
            android:alpha="0" />

        <com.oneandonly.thelaunch.AlphabetIndexBar
            android:id="@+id/alphabetBar"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </FrameLayout>

    <!-- Dock sits above the nav buttons; bottom padding is applied in code (nav inset)
         so the black home background still paints under the transparent system buttons. -->
    <LinearLayout
        android:id="@+id/llDock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0DFFFFFF"
        android:paddingHorizontal="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

</LinearLayout>
