<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <!-- Toolbar row -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:tint="#FFFFFF"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Display section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPLAY"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/rowSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Search"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switchSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowAlphabet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alphabet Index"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-Z scrubber on the home screen"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchAlphabet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowAppleClean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apple Watch Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="On: honeycomb apps with center zoom. Off: normal grid"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchAppleClean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowShowAppNames"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show App Names"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Labels under icons in grid and Apple Watch mode"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchShowAppNames"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowShowTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show Date &amp; Time"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sun/moon, AM/PM, and weekday date on the home bar"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchShowTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowShowStatusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show Status Bar"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System clock, battery, and icons. Off: full-bleed home; swipe down from top to peek"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchShowStatusBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowShowRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Refresh Button"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switchShowRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowShowAdd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Add Shortcut Button"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switchShowAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowHoneycombCloseness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Icon Closeness"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How tightly icons pack in Apple Watch mode"
                        android:textColor="#7C7C9C"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHoneycombClosenessValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekHoneycombCloseness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="55" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowGridColumns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Grid Columns"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvGridColumnsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekGridColumns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="3"
                android:progress="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowLabelSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Label Size"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvLabelSizeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekLabelSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="8"
                android:progress="2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowIconShape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Icon Shape"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <RadioGroup
                android:id="@+id/rgIconShape"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbRound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Round"
                    android:textColor="#FFFFFF" />

                <RadioButton
                    android:id="@+id/rbSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Square"
                    android:textColor="#FFFFFF"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbHexagon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Hexagon"
                    android:textColor="#FFFFFF" />

                <RadioButton
                    android:id="@+id/rbOriginal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Original"
                    android:textColor="#FFFFFF" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Original = app glyph only, transparent, no mask or background plate"
                android:textColor="#7C7C9C"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowCornerRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Corner Radius"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvCornerRadiusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekCornerRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="50"
                android:progress="20" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowIconScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Icon Zoom"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grid mode: zoom art inside each icon cell"
                        android:textColor="#7C7C9C"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvIconScaleValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:id="@+id/ivIconScalePreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekIconScale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="50" />
        </LinearLayout>

        <!-- Hidden apps section (collapsed by default; expand to manage) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIDDEN APPS"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/rowHiddenAppsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:clickable="true"
            android:focusable="true"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvHiddenAppsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Expand hidden apps"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvHiddenAppsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No hidden apps"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Fixed box so expand/collapse glyphs never clip or shift with label length -->
            <TextView
                android:id="@+id/tvHiddenAppsChevron"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="▸"
                android:textColor="#7C7C9C"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llHiddenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- About section (collapsed by default; expand on tap) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/rowAboutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:clickable="true"
            android:focusable="true"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvAboutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="theLaunch"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAboutChevron"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="▸"
                android:textColor="#7C7C9C"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llAboutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#14FFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.25"
                android:text="A simple grid launcher. No widgets, icon packs, or fluff. Just apps, search, and a dock.\n\nLoads from the OS on every open. No background services.\n\nSwipe or press back to refresh. Sometimes all you need is a launcher." />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
