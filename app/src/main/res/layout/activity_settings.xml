<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <!-- Toolbar row -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:tint="#FFFFFF"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Display section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPLAY"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/rowTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show Time"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(enabling time uses a tiny bit of extra battery)"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Wallpaper"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switchWallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Search"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switchSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowPortraitLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lock Portrait"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(disable to allow auto-rotate)"
                    android:textColor="#7C7C9C"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchPortraitLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowIconShape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Icon Shape"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <RadioGroup
                android:id="@+id/rgIconShape"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbNoCrop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Crop"
                    android:textColor="#FFFFFF"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbRound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="Round"
                    android:textColor="#FFFFFF" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowIconScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Icon Zoom"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvIconScaleValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7C7C9C"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:id="@+id/ivIconScalePreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekIconScale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="50" />
        </LinearLayout>

        <!-- Hidden apps section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIDDEN APPS"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvNoHiddenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hidden apps"
            android:textColor="#7C7C9C"
            android:textSize="13sp"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp" />

        <LinearLayout
            android:id="@+id/llHiddenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- About section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="#7C7C9C"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="theLaunch"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7C7C9C"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:text="theLaunch is a grid based launcher. No widgets, no icon packs, no customization. Just your apps, a search bar, and a dock.\n\nMost launchers run background services and cache resources before you even open them. theLaunch does none of that. It loads directly from the OS on every open.\n\nSwipe back or press the back gesture to refresh the app list.\n\nSometimes all you need is just a launcher." />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
